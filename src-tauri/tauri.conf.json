{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TurboDownload",
  "version": "1.0.2",
  "identifier": "com.turbodownload.desktop",
  "build": {
    "frontendDist": "./dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "TurboDownload",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "center": true,
        "decorations": true,
        "transparent": false,
        "focus": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; connect-src 'self' https: http:"
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon_32x32.png",
      "icons/icon_128x128.png",
      "icons/icon_256x256.png",
      "icons/icon_512x512.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": "all",
    "category": "Utility",
    "shortDescription": "A fast multi-threaded download manager",
    "longDescription": "TurboDownload is a high-performance download manager with multi-threaded downloading, breakpoint continuation, and web crawler capabilities.",
    "copyright": "Copyright © 2026 TurboDownload",
    "publisher": "TurboDownload",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    },
    "macOS": {
      "entitlements": null,
      "exceptionDomain": "",
      "frameworks": [],
      "providerShortName": null,
      "signingIdentity": null
    },
    "linux": {
      "appimage": {
        "bundleMediaFramework": false
      },
      "deb": {
        "depends": []
      },
      "rpm": {
        "depends": []
      }
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/yourusername/TurboDownload/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDU3OEFDMzEyM0M1MjM2N0EKUldSNk5sSThFc09LVjdKa0EySmc0bGdMdkFzcHBiSkJCcm1UbDVxNDZsNDB5OUdYSkZtZjBiUkkK"
    },
    "fs": {
      "requireLiteralLeadingDot": false
    },
    "shell": {
      "open": true
    }
  }
}